generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String    @default("user") // "user" or "admin"
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  ratings      Rating[]
  savedRecipes SavedRecipe[]
  reviews      Review[]
  mealPlans    MealPlan[]
  collections  Collection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  heroImage   String
  prepTime    Int // minutes
  cookTime    Int // minutes
  servings    Int
  difficulty  String   @default("Medium") // Easy, Medium, Hard
  source      String   @default("manual") // "manual", "csv", "ai"
  imageStatus String   @default("none") // "none", "pending", "generated", "skip"
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Estimated nutrition per serving (AI-generated, not verified)
  calories             Int?
  protein              Float?
  carbs                Float?
  fat                  Float?
  fiber                Float?
  sugar                Float?
  nutritionEstimatedAt DateTime?
  introGeneratedAt     DateTime?

  ingredients  RecipeIngredient[]
  steps        RecipeStep[]
  dietaryTags  RecipeDietaryTag[]
  categories   RecipeCategory[]
  occasions    RecipeOccasion[]
  ratings        Rating[]
  savedRecipes   SavedRecipe[]
  reviews        Review[]
  mealPlanEntries MealPlanEntry[]
  collections    CollectionRecipe[]
  shares         Share[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  score     Int // 1-5
  userId    String
  recipeId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model SavedRecipe {
  id        Int      @id @default(autoincrement())
  userId    String
  recipeId  Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model Ingredient {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  estimatedPrice Float? // estimated price in GBP
  priceUnit      String? // e.g. "per kg", "each"
  supermarket    String? // price source
  updatedAt      DateTime @updatedAt

  recipes RecipeIngredient[]
}

model RecipeIngredient {
  id           Int     @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     String // e.g. "2", "200g", "a pinch"
  unit         String? // e.g. "g", "ml", "tbsp"
  notes        String? // e.g. "finely chopped"
  orderIndex   Int

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

model RecipeStep {
  id          Int     @id @default(autoincrement())
  recipeId    Int
  stepNumber  Int
  instruction String
  image       String?
  tipText     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, stepNumber])
}

model DietaryTag {
  id   Int    @id @default(autoincrement())
  name String @unique // "Vegan", "Vegetarian", etc.
  slug String @unique

  recipes RecipeDietaryTag[]
}

model RecipeDietaryTag {
  recipeId     Int
  dietaryTagId Int

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  dietaryTag DietaryTag @relation(fields: [dietaryTagId], references: [id])

  @@id([recipeId, dietaryTagId])
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  slug        String  @unique
  description String?
  image       String?

  recipes RecipeCategory[]
}

model RecipeCategory {
  recipeId   Int
  categoryId Int

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([recipeId, categoryId])
}

model Setting {
  key   String @id
  value String
}

model Occasion {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  slug        String  @unique
  description String?
  startMonth  Int
  endMonth    Int

  recipes RecipeOccasion[]
}

model RecipeOccasion {
  recipeId   Int
  occasionId Int

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  occasion Occasion @relation(fields: [occasionId], references: [id])

  @@id([recipeId, occasionId])
}

model Review {
  id        Int      @id @default(autoincrement())
  text      String
  userId    String
  recipeId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model MealPlan {
  id        Int      @id @default(autoincrement())
  name      String   @default("My Meal Plan")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals MealPlanEntry[]
}

model MealPlanEntry {
  id         Int    @id @default(autoincrement())
  mealPlanId Int
  recipeId   Int
  day        String // "monday", "tuesday", etc.
  mealType   String // "breakfast", "lunch", "dinner", "snack"

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])
}

model Collection {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes CollectionRecipe[]

  @@unique([userId, slug])
}

model CollectionRecipe {
  id           Int      @id @default(autoincrement())
  collectionId Int
  recipeId     Int
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, recipeId])
}

model Share {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  platform  String
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model GenerationJob {
  id            Int      @id @default(autoincrement())
  status        String   @default("running") // "running", "stopping", "completed", "failed"
  category      String   @default("general") // "general", "baking", "soups", "bread"
  startOffset   Int
  currentOffset Int
  targetCount   Int      @default(0) // 0 = unlimited (continuous)
  batchSize     Int      @default(10)
  concurrency   Int      @default(3)
  successCount  Int      @default(0)
  errorCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
