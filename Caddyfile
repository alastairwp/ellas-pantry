www.ellaspantry.co.uk {
	header Permissions-Policy "microphone=(self)"
	handle /images/recipes/* {
		root * /var/www/ellas-pantry/public/images/recipes
		uri strip_prefix /images/recipes
		file_server
	}
	handle /images/avatars/* {
		root * /var/www/ellas-pantry/public/images/avatars
		uri strip_prefix /images/avatars
		file_server
	}
	reverse_proxy localhost:3000
}

http://ellaspantry.co.uk {
	redir https://www.ellaspantry.co.uk{uri} permanent
}

ellaspantry.co.uk {
	redir https://www.ellaspantry.co.uk{uri} permanent
}
