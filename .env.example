# Recipe generation
RECIPE_LLM_PROVIDER="local" # "claude" or "local" (Ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="mistral"

# Public
NEXT_PUBLIC_SITE_URL="https://www.ellaspantry.co.uk"
