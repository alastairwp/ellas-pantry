# Database (PostgreSQL)
DATABASE_URL="postgresql://ellaspantry:CHANGE_ME@db:5432/ellaspantry"
POSTGRES_PASSWORD="CHANGE_ME"

# Auth
AUTH_SECRET="generate-a-32-char-random-string"
AUTH_URL="https://www.ellaspantry.co.uk"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# APIs
ANTHROPIC_API_KEY="sk-ant-..."
PEXELS_API_KEY=""
UNSPLASH_ACCESS_KEY=""
